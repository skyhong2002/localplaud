# localplaud deployment secrets — copy to .env and fill in.
# .env is git-ignored; this template is committed.
#
# Every LOCALPLAUD_* variable overrides the matching config.toml field
# ("__" separates nesting levels). Keep secrets here, settings in config.toml.

# --------------------------------------------------------------------------- #
# Reverse proxy (Caddy)
# --------------------------------------------------------------------------- #
# The public domain Caddy serves; it must resolve to this host so
# Let's Encrypt can issue a certificate.
DOMAIN=plaud.example.com
# Contact email for Let's Encrypt (expiry notices etc.).
ACME_EMAIL=you@example.com

# --------------------------------------------------------------------------- #
# Plaud cloud (the data source)
# --------------------------------------------------------------------------- #
# The default provider is Plaud's OFFICIAL Open API — no secrets needed here.
# Sign in once with `localplaud auth login` (browser OAuth; tokens are cached
# in ~/.plaud/tokens.json and auto-refresh).
#
# The variables below are only for the optional legacy "apse1" session, used
# to enrich change-detection metadata (or as the primary provider if you set
# plaud.provider = "apse1"). See README "Your Plaud session".
# API host for YOUR account/region — check in the browser devtools console:
#   localStorage.getItem("pld_plaud_user_api_domain")
#LOCALPLAUD_PLAUD__API_BASE=https://api-apse1.plaud.ai
#LOCALPLAUD_PLAUD__COOKIE=

# --------------------------------------------------------------------------- #
# ASR (speech-to-text) — cloud provider keys
# --------------------------------------------------------------------------- #
# On the `cpu` profile (no GPU), pick a cloud ASR provider instead of the
# default local faster-whisper, e.g.:
#LOCALPLAUD_ASR__PROVIDER=deepgram    # or: openai | assemblyai
# ...and set the matching key:
#LOCALPLAUD_ASR__OPENAI__API_KEY=
#LOCALPLAUD_ASR__DEEPGRAM__API_KEY=
#LOCALPLAUD_ASR__ASSEMBLYAI__API_KEY=

# --------------------------------------------------------------------------- #
# Diarization (speaker separation)
# --------------------------------------------------------------------------- #
# Hugging Face token, needed once to download the pyannote models
# (gpu profile only; deepgram/assemblyai diarize server-side).
#LOCALPLAUD_DIARIZE__HF_TOKEN=

# --------------------------------------------------------------------------- #
# LLM (summaries, notes, Q&A) — cloud provider keys
# --------------------------------------------------------------------------- #
# Only needed if llm.provider in config.toml is openai/anthropic
# (the default is local Ollama, no key required).
#LOCALPLAUD_LLM__OPENAI__API_KEY=
#LOCALPLAUD_LLM__ANTHROPIC__API_KEY=
