# Keep the build context small and secrets out of the image.
.git
.github
.claude
.venv
venv
.uv
__pycache__
*.py[cod]
.ruff_cache
.pytest_cache
.mypy_cache
.coverage
htmlcov

# Local data & models (mounted as volumes at runtime, never baked in)
data/
models/
*.db
*.sqlite
*.opus
*.mp3
*.wav
*.m4a

# Secrets & local config
.env
.env.*
!.env.example
config.toml
*.cookie
*.token
secrets/

# Session / handoff artifacts
HANDOFF.md
GOAL_CONDITION.md
GOAL_PROMPT.md

# Docs/tests aren't needed in the runtime image
docs/
tests/
*.md
!README.md
